# Step 1: Define names and steps
names = ["Me", "Lia", "Jake"]
steps = [
    [4500, 5200, 4800, 5000, 5300],
    [4000, 4100, 3900, 4200, 4600],
    [6000, 5800, 5900, 6100, 6200]
]

# Step 2: Calculate total steps for each person
total_steps = [sum(person_steps) for person_steps in steps]

# Step 3: Identify the person with the highest total steps
max_steps = max(total_steps)
min_steps = min(total_steps)
max_index = total_steps.index(max_steps)

# Step 4: Print the person with the highest total steps
print(f"{names[max_index]} has the highest total steps: {max_steps}")

# Step 5: Display the difference between the highest and lowest total
difference = max_steps - min_steps
print(f"The difference between the highest and lowest total steps is: {difference}")
